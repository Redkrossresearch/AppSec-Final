# ─────────────────────────────────────────────────────────
# Secrets & environment  (NEVER commit these)
# ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# ─────────────────────────────────────────────────────────
# Flask / SQLAlchemy runtime
# ─────────────────────────────────────────────────────────
instance/
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────
# App runtime data  (auto-created on startup by create_app)
# ─────────────────────────────────────────────────────────
scans/
uploads/
logs/
reports/

# DeepSec document-sanitizer output. Per-scan copies live under reports/ (ignored above);
# this catches any standalone-default writes to the repo root.
sanitized/

# Keep generated onboarding/report docs but drop ad-hoc PDFs/exports
reports/pdf/
reports/csv/
reports/downloads/

# ─────────────────────────────────────────────────────────
# Test / coverage / type-check caches
# ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────────────────
# Scratch / generated files
# ─────────────────────────────────────────────────────────
tree.txt
project_tree.txt

# ─────────────────────────────────────────────────────────
# IDE / editor
# ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────
# OS cruft
# ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

*.zip
docs/today_work_summary.pdf

