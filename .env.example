# AppSec Orchestrator - Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
APP_SECRET_KEY=your-secret-key-change-me-in-production
FLASK_DEBUG=0

# Database (default: SQLite in instance/appsec.db)
DATABASE_URL=sqlite:///./instance/appsec.db

# File Upload Configuration
MAX_SCAN_FILE_SIZE=524288  # 512 KB - max file size to scan

# Claude AI API Configuration (for AI-powered fixing)
# Get your API key from https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ENABLE_AI_FIXER=1

# Optional: Slack/Email Notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=your-email@example.com
# EMAIL_PASSWORD=your-app-password
